{
  "name": "layang",
  "version": "1.0.5",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "dev:next": "next dev",
    "dev:with-local-grpc-web-proxy": "concurrently -k \"next dev\" \"node scripts/grpc-web-dev-proxy.cjs\"",
    "build": "next build",
    "start": "next start",
    "desktop": "concurrently -k \"pnpm run dev\" \"wait-on http://localhost:3000/playground && electron-forge start\"",
    "desktop:preview": "pnpm run build && node scripts/start-forge-static.cjs",
    "desktop:pack": "pnpm run build && electron-forge package",
    "desktop:dist": "pnpm run build && electron-forge make",
    "clean": "node -e \"require('node:fs').rmSync('.next',{recursive:true,force:true});require('node:fs').rmSync('out',{recursive:true,force:true});require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck && pnpm run test:ci && pnpm run lint && pnpm run build && pnpm run docs:build",
    "desktop:portable": "pnpm run desktop:win:portable",
    "desktop:win": "pnpm run build && electron-forge make --platform=win32",
    "desktop:win:installer": "pnpm run desktop:win:setup:squirrel",
    "desktop:win:setup": "pnpm run desktop:win:setup:squirrel",
    "desktop:win:setup:squirrel": "pnpm run build && electron-forge make --platform=win32 --targets=@electron-forge/maker-squirrel",
    "desktop:win:setup:msi": "node scripts/check-wix-toolset.cjs && pnpm run build && electron-forge make --platform=win32 --targets=@electron-forge/maker-wix",
    "desktop:win:portable": "pnpm run build && electron-forge make --platform=win32 --targets=@electron-forge/maker-zip",
    "desktop:linux": "pnpm run build && electron-forge make --platform=linux",
    "desktop:linux:deb": "pnpm run build && electron-forge make --platform=linux --targets=@electron-forge/maker-deb",
    "desktop:linux:rpm": "pnpm run build && electron-forge make --platform=linux --targets=@electron-forge/maker-rpm",
    "desktop:deb": "pnpm run desktop:linux:deb",
    "desktop:rpm": "pnpm run desktop:linux:rpm",
    "cli": "node bin/layang.cjs",
    "cli:smoke": "node bin/layang.cjs --help",
    "test:unit": "node --test tests/*.test.cjs",
    "test:e2e": "node --test tests/e2e/*.test.cjs",
    "test:ci": "pnpm run test:unit && pnpm run cli:smoke",
    "test:all": "pnpm run test:unit && pnpm run test:e2e && pnpm run cli:smoke",
    "docs:build": "node scripts/validate-github-pages.cjs",
    "docs:dev": "node scripts/serve-github-pages.cjs",
    "docs:serve": "node scripts/serve-github-pages.cjs",
    "deps:audit": "pnpm audit",
    "deps:refresh": "pnpm install --lockfile-only && pnpm audit"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@electron-forge/cli": "7.11.1",
    "@electron-forge/maker-deb": "7.11.1",
    "@electron-forge/maker-dmg": "7.11.1",
    "@electron-forge/maker-rpm": "7.11.1",
    "@electron-forge/maker-squirrel": "7.11.1",
    "@electron-forge/maker-wix": "7.11.1",
    "@electron-forge/maker-zip": "7.11.1",
    "@radix-ui/react-slot": "1.2.4",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "concurrently": "9.2.1",
    "electron": "42.1.0",
    "lucide-react": "1.16.0",
    "next": "16.2.6",
    "postcss": "8.5.14",
    "protobufjs": "8.3.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "tailwindcss-animate": "1.0.7",
    "typescript": "6.0.3",
    "wait-on": "9.0.10"
  },
  "description": "Layang is a local-first REST, WebSocket, gRPC, gRPC-Web, mock server, benchmark, and documentation workbench with portable workspace folders.",
  "productName": "Layang",
  "license": "MIT",
  "author": "Layang contributors",
  "homepage": "https://github.com/flik-lab/layang#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flik-lab/layang.git"
  },
  "bugs": {
    "url": "https://github.com/flik-lab/layang/issues"
  },
  "keywords": [
    "git-friendly",
    "workspace-folder",
    "api-client",
    "local-first",
    "layang",
    "grpc",
    "grpc-web",
    "rest",
    "websocket",
    "protobuf",
    "api-testing",
    "api-documentation",
    "electron",
    "apisix",
    "developer-portal",
    "landing-page",
    "grpc-tools",
    "proto-registry",
    "multi-tabs",
    "grpc-streaming",
    "console-logging"
  ],
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=10.0.0"
  },
  "bin": {
    "layang": "./bin/layang.cjs"
  },
  "private": true,
  "packageManager": "pnpm@10.12.4+sha512.5ea8b0deed94ed68691c9bad4c955492705c5eeb8a87ef86bc62c74a26b037b08ff9570f108b2e4dbd1dd1a9186fea925e527f141c648e85af45631074680184",
  "pnpm": {
    "overrides": {
      "@tootallnate/once": "^3.0.1",
      "postcss": "^8.5.14",
      "tar": "^7.5.13",
      "tmp": "^0.2.5"
    }
  }
}
